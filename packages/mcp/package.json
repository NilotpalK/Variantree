{
  "name": "@variantree/mcp",
  "version": "0.2.0",
  "description": "MCP server for Variantree — exposes checkpoint/branch/restore as AI-callable tools",
  "type": "module",
  "main": "dist/server.js",
  "types": "dist/server.d.ts",
  "bin": {
    "variantree-mcp": "./dist/server.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build:web": "cd ../web && npm run build && mkdir -p ../mcp/dist/web-ui && cp -r dist/. ../mcp/dist/web-ui/",
    "build": "npm run build:web && tsc",
    "dev": "tsc --watch",
    "start": "node dist/server.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "mcp",
    "variantree",
    "ai",
    "opencode",
    "model-context-protocol"
  ],
  "license": "Apache-2.0",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "@variantree/core": "^0.1.0",
    "@variantree/watcher": "^0.2.0",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
