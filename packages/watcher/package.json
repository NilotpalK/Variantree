{
  "name": "@variantree/watcher",
  "version": "0.1.5",
  "description": "Passive session file watcher and CLI for Variantree",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "variantree": "./dist/cli.js"
  },
  "files": [
    "dist",
    "scripts"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "postinstall": "node scripts/postinstall.cjs"
  },
  "keywords": [
    "ai",
    "conversation",
    "version-control",
    "watcher",
    "opencode",
    "claude-code"
  ],
  "license": "PolyForm-Noncommercial-1.0.0",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@variantree/core": "^0.1.0",
    "better-sqlite3": "^12.9.0",
    "chalk": "^5.6.2",
    "chokidar": "^4.0.3",
    "commander": "^12.1.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
